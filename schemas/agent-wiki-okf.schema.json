{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/xinhuagu/agent-wiki/schemas/agent-wiki-okf.schema.json",
  "title": "Agent Wiki Open Knowledge Format Manifest",
  "description": "Portable package manifest for Agent Wiki OKF v0.1 knowledge packages.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "format_version",
    "name",
    "version",
    "license",
    "owner",
    "created_at",
    "source_policy",
    "wiki_policy",
    "evidence_policy"
  ],
  "properties": {
    "format": {
      "const": "agent-wiki-okf",
      "description": "Manifest format identifier."
    },
    "format_version": {
      "description": "OKF format version. YAML parsers may load 0.1 as a number, so both forms are accepted.",
      "oneOf": [
        { "const": "0.1" },
        { "const": 0.1 }
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$",
      "description": "Portable package name."
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Package version, typically semver."
    },
    "license": {
      "type": "string",
      "minLength": 1,
      "description": "License or access policy identifier for the package content."
    },
    "owner": {
      "type": "string",
      "minLength": 1,
      "description": "Team, person, or system responsible for the package."
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}($|T)",
      "description": "Package creation date as YYYY-MM-DD or ISO 8601 datetime."
    },
    "description": {
      "type": "string"
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw_immutable", "require_sha256"],
      "properties": {
        "raw_immutable": {
          "type": "boolean",
          "const": true
        },
        "require_sha256": {
          "type": "boolean",
          "const": true
        },
        "require_meta_sidecars": {
          "type": "boolean"
        }
      }
    },
    "wiki_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["require_sources_for_grounded_pages", "allow_synthesis_pages"],
      "properties": {
        "require_sources_for_grounded_pages": {
          "type": "boolean"
        },
        "allow_synthesis_pages": {
          "type": "boolean"
        },
        "stale_after_days": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "evidence_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allow_unsupported_pages", "require_abstain_signal"],
      "properties": {
        "allow_unsupported_pages": {
          "type": "string",
          "enum": ["allow", "warn", "reject"]
        },
        "require_abstain_signal": {
          "type": "boolean"
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Freeform package metadata for tool-specific annotations."
    }
  }
}
